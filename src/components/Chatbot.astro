---
// src/components/Chatbot.astro
// Floating RAG chatbot powered by Groq API
// Embeddings loaded from /public/embeddings.json (generated by scripts/ingest.py)
const GROQ_API_KEY = import.meta.env.PUBLIC_GROQ_API_KEY;
---

<!-- Floating Chat Button -->
<button
  id="chat-fab"
  aria-label="Open portfolio assistant"
  title="Ask me anything about Krishna!"
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
  <span id="fab-label">Ask AI</span>
</button>

<!-- Chat Window -->
<div id="chat-window" class="chat-hidden" role="dialog" aria-label="Portfolio Assistant">
  <!-- Header -->
  <div id="chat-header">
    <div class="header-left">
      <div class="avatar">KS</div>
      <div>
        <div class="header-name">Krishna's Assistant</div>
        <div class="header-status">
          <span class="status-dot"></span>
          <span id="status-text">Online</span>
        </div>
      </div>
    </div>
    <button id="chat-close" aria-label="Close chat">✕</button>
  </div>

  <!-- Messages -->
  <div id="chat-messages"></div>

  <!-- Quick Chips -->
  <div id="chips-container">
    <button class="chip" data-msg="What are Krishna's skills?">Skills</button>
    <button class="chip" data-msg="Tell me about Krishna's projects">Projects</button>
    <button class="chip" data-msg="How can I contact Krishna?">Contact</button>
    <button class="chip" data-msg="Is Krishna available for hire?">Hire?</button>
  </div>

  <!-- Input -->
  <div id="chat-input-area">
    <input
      id="chat-input"
      type="text"
      placeholder="Ask about skills, projects, contact..."
      autocomplete="off"
    />
    <button id="chat-send" aria-label="Send message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </div>
</div>

<style>
  /* ── FAB Button ─────────────────────────────────── */
  #chat-fab {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px 12px 16px;
    background: #7c3aed;
    color: white;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    font-family: inherit;
    box-shadow: 0 4px 20px rgba(124, 58, 237, 0.4);
    transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
  }
  #chat-fab:hover {
    background: #6d28d9;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(124, 58, 237, 0.5);
  }
  #chat-fab:active { transform: scale(0.97); }

  /* ── Chat Window ────────────────────────────────── */
  #chat-window {
    position: fixed;
    bottom: 90px;
    right: 28px;
    z-index: 9998;
    width: 360px;
    height: 500px;
    background: var(--color-background, #fff);
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.15);
    transition: opacity 0.25s, transform 0.25s;
  }
  #chat-window.chat-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(16px) scale(0.97);
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    #chat-window {
      background: #1a1a2e;
      border-color: rgba(255,255,255,0.1);
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    #chat-window {
      width: calc(100vw - 24px);
      right: 12px;
      bottom: 85px;
    }
    #chat-fab { right: 16px; bottom: 20px; }
  }

  /* ── Header ─────────────────────────────────────── */
  #chat-header {
    background: linear-gradient(135deg, #7c3aed, #5b21b6);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .header-left { display: flex; align-items: center; gap: 10px; }
  .avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 600; color: white;
  }
  .header-name { font-size: 14px; font-weight: 600; color: white; }
  .header-status { display: flex; align-items: center; gap: 5px; margin-top: 2px; }
  .status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
  #status-text { font-size: 11px; color: rgba(255,255,255,0.8); }
  #chat-close {
    background: rgba(255,255,255,0.15);
    border: none; color: white; cursor: pointer;
    width: 28px; height: 28px; border-radius: 50%;
    font-size: 13px; display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  #chat-close:hover { background: rgba(255,255,255,0.3); }

  /* ── Messages ───────────────────────────────────── */
  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
  }
  #chat-messages::-webkit-scrollbar { width: 4px; }
  #chat-messages::-webkit-scrollbar-track { background: transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background: rgba(124,58,237,0.3); border-radius: 4px; }

  .msg { display: flex; gap: 8px; animation: fadeSlide 0.2s ease; }
  @keyframes fadeSlide { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
  .msg.user { flex-direction: row-reverse; }

  .msg-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: #ede9fe; color: #7c3aed;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 600; flex-shrink: 0; margin-top: 2px;
  }

  .bubble {
    max-width: 240px;
    padding: 9px 13px;
    border-radius: 16px;
    font-size: 13.5px;
    line-height: 1.55;
    word-break: break-word;
  }
  .msg.bot .bubble {
    background: #f3f0ff;
    color: #1e1b4b;
    border-radius: 4px 16px 16px 16px;
  }
  .msg.user .bubble {
    background: #7c3aed;
    color: white;
    border-radius: 16px 4px 16px 16px;
  }
  .chat-link {
    color: #8b5cf6;
    text-decoration: underline;
  }
  @media (prefers-color-scheme: dark) {
    .msg.bot .bubble { background: #2d2b55; color: #e2e0ff; }
  }

  /* Typing indicator */
  .typing-bubble { display: flex; gap: 5px; align-items: center; padding: 12px 16px; }
  .typing-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #a78bfa;
    animation: bounce 1.2s infinite;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-5px)} }

  /* ── Chips ──────────────────────────────────────── */
  #chips-container {
    display: flex;
    gap: 6px;
    padding: 0 12px 10px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .chip {
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 12px;
    cursor: pointer;
    background: #ede9fe;
    color: #5b21b6;
    border: 1px solid #c4b5fd;
    font-family: inherit;
    transition: background 0.15s, transform 0.1s;
  }
  .chip:hover { background: #ddd6fe; transform: translateY(-1px); }
  .chip:active { transform: scale(0.97); }
  @media (prefers-color-scheme: dark) {
    .chip { background: #2d2b55; color: #c4b5fd; border-color: #4c1d95; }
    .chip:hover { background: #3d3b6e; }
  }

  /* ── Input Area ─────────────────────────────────── */
  #chat-input-area {
    padding: 10px 12px;
    border-top: 1px solid rgba(0,0,0,0.08);
    display: flex;
    gap: 8px;
    align-items: center;
    flex-shrink: 0;
  }
  @media (prefers-color-scheme: dark) {
    #chat-input-area { border-top-color: rgba(255,255,255,0.08); }
  }
  #chat-input {
    flex: 1;
    padding: 9px 14px;
    border-radius: 24px;
    border: 1.5px solid #e0d9ff;
    background: #faf8ff;
    font-size: 13.5px;
    font-family: inherit;
    color: inherit;
    outline: none;
    transition: border-color 0.15s;
  }
  #chat-input:focus { border-color: #7c3aed; }
  @media (prefers-color-scheme: dark) {
    #chat-input { background: #2d2b55; border-color: #4c1d95; color: #e2e0ff; }
  }
  #chat-send {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #7c3aed;
    border: none; color: white; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s, transform 0.1s;
  }
  #chat-send:hover { background: #6d28d9; }
  #chat-send:active { transform: scale(0.95); }
  #chat-send:disabled { background: #c4b5fd; cursor: not-allowed; }
</style>

<script define:vars={{ GROQ_API_KEY }}>
// ── Constants ────────────────────────────────────────────────────────────────
const SYSTEM_PROMPT = `You are a professional and polite portfolio assistant for Krishna Singh — an Aspiring Machine Learning Engineer & Full Stack Developer from Kanpur, India.

Your job is to impress visitors and represent Krishna in the best possible light.

Guidelines:
- Always respond in fluent, professional English
- Be warm, confident, and enthusiastic about Krishna's work
- Keep responses to 2-3 short sentences maximum. Be crisp and direct.
- Never write long paragraphs. Quality over quantity.
- Highlight Krishna's strengths naturally in every relevant answer
- Use bullet points only when listing multiple items
- Never say "I don't know" — if unsure, redirect to his contact info
- End responses with a subtle call-to-action when appropriate (e.g. "Feel free to reach out!")

Contact details:
- Email: ksingh75224@gmail.com
- Phone: +91-9628251125
- GitHub: https://github.com/Krishna329-dot
- LinkedIn: https://www.linkedin.com/in/krishna-singh-108b01366
- Portfolio: https://printfolio.vercel.app

Always use the resume context provided to give accurate, specific answers about his skills, projects, and experience.`;

// ── State ────────────────────────────────────────────────────────────────────
let isOpen = false;
let isLoading = false;
let history = [];
let embeddingsData = null;

// ── DOM Refs ─────────────────────────────────────────────────────────────────
const fab = document.getElementById('chat-fab');
const chatWindow = document.getElementById('chat-window');
const closeBtn = document.getElementById('chat-close');
const messagesEl = document.getElementById('chat-messages');
const inputEl = document.getElementById('chat-input');
const sendBtn = document.getElementById('chat-send');
const chipsEl = document.getElementById('chips-container');
const statusText = document.getElementById('status-text');
const fabLabel = document.getElementById('fab-label');

// ── Toggle chat ──────────────────────────────────────────────────────────────
fab.addEventListener('click', () => {
  isOpen = !isOpen;
  chatWindow.classList.toggle('chat-hidden', !isOpen);
  fabLabel.textContent = isOpen ? 'Close' : 'Ask AI';
  if (isOpen && history.length === 0) {
    showWelcome();
    loadEmbeddings();
  }
  if (isOpen) inputEl.focus();
});

closeBtn.addEventListener('click', () => {
  isOpen = false;
  chatWindow.classList.add('chat-hidden');
  fabLabel.textContent = 'Ask AI';
});

// ── Welcome message ──────────────────────────────────────────────────────────
function showWelcome() {
  if (history.length === 0 && messagesEl.children.length === 0) {
    addMessage('bot', 'Hi! 👋 I\'m Krishna\'s portfolio assistant. Ask me about his skills, projects, or how to get in touch!');
  }
}

// ── Load embeddings.json ─────────────────────────────────────────────────────
async function loadEmbeddings() {
  try {
    statusText.textContent = 'Loading...';
    const res = await fetch('/embeddings.json');
    if (!res.ok) throw new Error('Not found');
    embeddingsData = await res.json();
    statusText.textContent = 'Online';
  } catch (e) {
    statusText.textContent = 'Online';
    embeddingsData = null;
  }
}

// ── RAG: cosine similarity ───────────────────────────────────────────────────
function cosineSimilarity(a, b) {
  let dot = 0, magA = 0, magB = 0;
  for (let i = 0; i < a.length; i++) {
    dot += a[i] * b[i];
    magA += a[i] * a[i];
    magB += b[i] * b[i];
  }
  const denom = Math.sqrt(magA) * Math.sqrt(magB);
  return denom === 0 ? 0 : dot / denom;
}

function queryEmbedding(queryText) {
  if (!embeddingsData) return null;
  const { vocab, chunks } = embeddingsData;
  const words = queryText.toLowerCase().match(/\b\w+\b/g) || [];
  const wordCount = {};
  words.forEach(w => wordCount[w] = (wordCount[w] || 0) + 1);
  const total = words.length || 1;
  const vec = vocab.map(term => (wordCount[term] || 0) / total);
  // L2 normalize
  const mag = Math.sqrt(vec.reduce((s, x) => s + x * x, 0));
  const normVec = mag === 0 ? vec : vec.map(x => x / mag);
  return normVec;
}

function retrieveContext(query, topK = 3) {
  if (!embeddingsData) return '';
  const queryVec = queryEmbedding(query);
  if (!queryVec) return '';
  const { chunks } = embeddingsData;
  const scored = chunks.map(chunk => ({
    text: chunk.text,
    score: cosineSimilarity(queryVec, chunk.embedding)
  }));
  scored.sort((a, b) => b.score - a.score);
  return scored.slice(0, topK).map(c => c.text).join('\n\n');
}

// ── Send message ─────────────────────────────────────────────────────────────
async function sendMessage(text) {
  if (!text.trim() || isLoading) return;
  text = text.trim();

  // Hide chips after first message
  chipsEl.style.display = 'none';

  addMessage('user', text);
  inputEl.value = '';
  history.push({ role: 'user', content: text });

  setLoading(true);
  const typingEl = showTyping();

  try {
    // RAG: get relevant context from resume
    const context = retrieveContext(text);
    const systemWithContext = context
      ? `${SYSTEM_PROMPT}\n\nRelevant context from Krishna's resume:\n${context}`
      : SYSTEM_PROMPT;

    const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${GROQ_API_KEY}`
      },
      body: JSON.stringify({
        model: 'llama-3.3-70b-versatile',
        max_tokens: 150,
        temperature: 0.7,
        messages: [
          { role: 'system', content: systemWithContext },
          ...history.slice(-6)
        ]
      })
    });

    const data = await res.json();
    typingEl.remove();

    if (data.error) {
      addMessage('bot', 'Sorry, kuch error aa gaya. Thodi der baad try karo!');
      history.pop();
    } else {
      const reply = data.choices?.[0]?.message?.content || 'Sorry, I could not generate a response.';
      addMessage('bot', reply);
      history.push({ role: 'assistant', content: reply });
    }
  } catch (err) {
    typingEl.remove();
    addMessage('bot', 'Network error. Please try again!');
    history.pop();
  }

  setLoading(false);
}

// ── UI Helpers ───────────────────────────────────────────────────────────────
function formatMessage(text) {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" rel="noopener noreferrer" class="chat-link">$1</a>')
    .replace(/\n/g, '<br>');
}

function addMessage(role, text) {
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  if (role === 'bot') {
    div.innerHTML = `
      <div class="msg-avatar">KS</div>
      <div class="bubble">${formatMessage(text)}</div>`;
  } else {
    div.innerHTML = `<div class="bubble">${formatMessage(text)}</div>`;
  }
  messagesEl.appendChild(div);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function showTyping() {
  const div = document.createElement('div');
  div.className = 'msg bot';
  div.innerHTML = `
    <div class="msg-avatar">KS</div>
    <div class="bubble" style="padding:10px 14px">
      <div class="typing-bubble">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    </div>`;
  messagesEl.appendChild(div);
  messagesEl.scrollTop = messagesEl.scrollHeight;
  return div;
}

function setLoading(val) {
  isLoading = val;
  sendBtn.disabled = val;
  inputEl.disabled = val;
}

// ── Event Listeners ──────────────────────────────────────────────────────────
sendBtn.addEventListener('click', () => sendMessage(inputEl.value));
inputEl.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage(inputEl.value);
  }
});

document.querySelectorAll('.chip').forEach(chip => {
  chip.addEventListener('click', () => sendMessage(chip.dataset.msg));
});
</script>
